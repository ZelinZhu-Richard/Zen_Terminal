# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ───────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Distribution / packaging ───────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Logs ──────────────────────────────────────────────────────────────────
logs/*.log
logs/*.log.*

# ── Audio (user-provided; not committed) ──────────────────────────────────
*.mp3
*.wav
*.ogg
*.flac

# ── macOS ─────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── IDEs ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Patched launchd plist (contains real local paths) ─────────────────────
