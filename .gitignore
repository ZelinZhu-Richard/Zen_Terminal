scripts/com.zenterminal.daemon.patched.plist

# ── pytest / coverage ─────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# ── mypy ──────────────────────────────────────────────────────────────────
.mypy_cache/

# ── ruff ──────────────────────────────────────────────────────────────────
.ruff_cache/

